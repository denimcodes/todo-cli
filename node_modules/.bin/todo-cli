#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/denimdev/Code/todo-cli/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/denimdev/Code/todo-cli/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/tsx" ]; then
  exec "$basedir/tsx"  "$basedir/../todo-cli/src/index.ts" "$@"
else
  exec tsx  "$basedir/../todo-cli/src/index.ts" "$@"
fi
